# ============================================================================
# Home Passport + Home OS — environment variables
# Copy to `.env.local` for local dev; set the same keys in Vercel for production.
# Required vars are validated at runtime by lib/env.ts (a misconfigured deploy
# fails fast with a readable bilingual error). Keep this file in sync with that
# schema. See DEPLOY.md for the full production checklist.
# ============================================================================

# --- Supabase (EU region project) ---------------------------- [REQUIRED] ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- AI provider (multimodal: doc extraction, vision, RAG) --- [REQUIRED] ----
# Keep data in EU: use an EU region / EU inference endpoint and sign a DPA.
OPENAI_API_KEY=YOUR-OPENAI-KEY
AI_MODEL=gpt-5.5
# Optional provider label (informational, surfaced in the UI). Default: openai.
AI_PROVIDER=openai
# Optional EU inference endpoint (sign a DPA). Leave unset for the default.
# AI_BASE_URL=https://YOUR-EU-ENDPOINT/v1
# Optional hard per-request timeout (ms) for every AI provider call so a hung
# connection fails fast instead of holding a route open. Default 30000; floor 1000.
# AI_TIMEOUT_MS=30000

# --- Transactional email (Resend) ---------------------------- [OPTIONAL] ----
# Server-only. When UNSET, email sending is a safe no-op (logs + skips), so
# dev/CI work without it. Set in production to actually deliver handover invites.
# RESEND_API_KEY=YOUR-RESEND-API-KEY
# Verified sender. Format: "Display Name <address@your-verified-domain>".
# Falls back to a branded default when unset.
# EMAIL_FROM=Home Passport <noreply@homepassport.app>

# --- Public URLs --------------------------------------------- [OPTIONAL] ----
# Public origin used to build shareable handover links (the B2B deliverable).
# Set this in production; behind a proxy it also falls back to x-forwarded-* .
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical site URL for sitemap.xml / robots.txt / canonical metadata.
# Defaults to http://localhost:3000 when unset.
# NEXT_PUBLIC_SITE_URL=https://homepassport.app
