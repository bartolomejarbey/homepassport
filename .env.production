# .env.production — bootstrap env so the Vercel deploy RUNS instead of throwing
# Internal Server Error. Next.js loads this file at build/runtime on Vercel.
#
# WHY committed: the Vercel API/dashboard couldn't be reached from the build
# environment, so the env vars are seeded here through the repo instead. Any real
# values you later set in Vercel → Settings → Environment Variables OVERRIDE this
# file (real process.env wins over .env files), so this is just a safe default.
#
# These Supabase/OpenAI values are PLACEHOLDERS — the site renders and is
# clickable via the login-bypass, but there is no real backend yet. Replace them
# with a real Supabase EU project + OpenAI key (in the Vercel dashboard) for
# working auth/data, and then REMOVE the bypass flag below.

# --- Supabase (placeholder) ---
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# --- AI (placeholder) ---
OPENAI_API_KEY=placeholder-openai-key
AI_MODEL=gpt-4o

# --- Public URLs ---
NEXT_PUBLIC_APP_URL=https://aurahomes.cz
NEXT_PUBLIC_SITE_URL=https://aurahomes.cz

# --- Pre-launch preview: enables the "Přeskočit přihlášení" button on the live
# site so you can click through the UI with no backend. REMOVE THIS once the
# deployment holds real user data (it lets anyone skip login). ---
NEXT_PUBLIC_ALLOW_DEV_BYPASS=1
